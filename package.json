{
  "name": "merca-facil",
  "version": "1.0.0",
  "main": "index.js",
  "author": "Guilherme de Almeida Laurentino",
  "license": "MIT",
  "private": false,
  "scripts": {
  "dev": "ts-node-dev --files ./src/index.ts",
  "build": "tsc",
  "start": "node ./build/index.js",
  "postinstall": "tsc",
  "knex:migrate": "ts-node node_modules/knex/bin/cli.js --knexfile ./src/server/database/knex/Environment.ts migrate:latest",
  "knex:rollback": "ts-node node_modules/knex/bin/cli.js --knexfile ./src/server/database/knex/Environment.ts migrate:rollback",
  "knex:rollback-all": "ts-node node_modules/knex/bin/cli.js --knexfile ./src/server/database/knex/Environment.ts migrate:rollback --all",
  "knex:seed": "ts-node node_modules/knex/bin/cli.js --knexfile ./src/server/database/knex/Environment.ts seed:run"
},
  "dependencies": {
  "bcryptjs": "^3.0.3",
  "cors": "^2.8.6",
  "dotenv": "^17.4.0",
  "express": "^5.2.1",
  "http-status-codes": "^2.3.0",
  "jsonwebtoken": "^9.0.3",
  "knex": "^3.2.9",
  "nodemailer": "^8.0.10",
  "pg": "^8.20.0",
  "yup": "^1.7.1",
  "@types/bcryptjs": "^3.0.0",
  "@types/cors": "^2.8.19",
  "@types/express": "^5.0.6",
  "@types/jsonwebtoken": "^9.0.10",
  "@types/nodemailer": "^8.0.0",
  "@types/pg": "^8.20.0",
  "typescript": "^6.0.2",
  "ts-node": "^10.9.2"
},
"devDependencies": {
  "@types/jest": "^30.0.0",
  "@types/supertest": "^7.2.0",
  "@eslint/css": "^1.0.0",
  "@eslint/js": "^10.0.1",
  "@eslint/json": "^1.2.0",
  "@eslint/markdown": "^8.0.0",
  "eslint": "^10.1.0",
  "globals": "^17.6.0",
  "jest": "^30.3.0",
  "sqlite3": "^6.0.1",
  "supertest": "^7.2.2",
  "ts-jest": "^29.4.9",
  "ts-node-dev": "^2.0.0",
  "typescript-eslint": "^8.57.2"
}
}
